<!--index.wxml-->
<view class="container">
  <!-- 头部区域 -->
  <view class="header">
    <view class="welcome">
      <text class="welcome-text">北肿工程科请假系统</text>
    </view>
  </view>

  <!-- 管理员状态显示 -->
  <view class="admin-status">
    <view class="status-card" wx:if="{{isAdmin}}">
      <view class="status-info">
        <text class="status-icon">👑</text>
        <text class="status-text">管理员已登录</text>
      </view>
      <button class="logout-btn" bindtap="handleLogout">退出登录</button>
    </view>
    
    <!-- 管理员登录入口 -->
    <view class="login-card" wx:else>
      <view class="login-info">
        <text class="login-icon">🔐</text>
        <text class="login-text">管理员登录</text>
        <text class="login-subtext">请输入密码访问管理功能</text>
      </view>
      <button class="login-btn" bindtap="showLoginModal">立即登录</button>
    </view>
  </view>

  <!-- 今日请假统计 -->
  <view class="stats-section">
    <view class="section-title">📅 今日请假情况</view>
    <view class="stats-card">
      <view class="stat-item" wx:if="{{todayLeaveStats.length > 0}}">
        <text class="stat-number">{{todayLeaveStats.length}}</text>
        <text class="stat-label">人请假</text>
      </view>
      <view class="stat-item" wx:else>
        <text class="stat-number">0</text>
        <text class="stat-label">人请假</text>
      </view>
      <view class="leave-list" wx:if="{{todayLeaveStats.length > 0}}">
        <view class="leave-item" wx:for="{{todayLeaveStats}}" wx:key="_id">
          <text class="leave-name">{{item.name}}</text>
          <text class="leave-period">{{item.period === 'full' ? '全天' : item.period === 'morning' ? '上午' : '下午'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="functions-section">
    <view class="section-title">🚀 功能导航</view>
    <view class="function-grid">
      <view 
        class="function-card" 
        wx:for="{{functionList}}" 
        wx:key="title"
        wx:if="{{!item.adminOnly || isAdmin}}"
        data-index="{{index}}"
        bindtap="onFunctionClick"
      >
        <view class="card-icon" style="background: {{item.color}}">{{item.icon}}</view>
        <view class="card-content">
          <text class="card-title">{{item.title}}</text>
          <text class="card-subtitle">{{item.subtitle}}</text>
        </view>
        <view class="card-badge" wx:if="{{item.adminOnly}}">管理员</view>
        <!-- 审批管理小红点 -->
        <view 
          class="red-dot" 
          wx:if="{{item.title === '✅ 审批管理' && pendingCount > 0}}"
        ></view>
      </view>
    </view>
  </view>

  <!-- 管理员工具 -->
  <view class="admin-tools" wx:if="{{isAdmin}}">
    <view class="section-title">🛠️ 管理员工具</view>
    <view class="tools-grid">
      <button class="tool-btn" bindtap="cleanInvalidData">
        <text class="tool-icon">🧹</text>
        <text class="tool-text">清理无效数据</text>
      </button>
    </view>
  </view>

  <!-- 登录模态框 -->
  <view class="login-modal" wx:if="{{showLoginModal}}">
    <view class="modal-mask" bindtap="hideLoginModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">🔐 管理员登录</text>
        <text class="modal-subtitle">请输入管理员密码</text>
      </view>
      
      <view class="modal-body">
        <view class="input-group">
          <text class="input-label">密码</text>
          <input 
            class="password-input {{isPasswordFocused ? 'focused' : ''}}"
            type="password" 
            placeholder="请输入管理员密码" 
            value="{{password}}"
            bindinput="onPasswordInput"
            bindfocus="onPasswordFocus"
            bindblur="onPasswordBlur"
          />
        </view>
      </view>
      
      <view class="modal-footer">
        <button class="modal-cancel-btn" bindtap="hideLoginModal">取消</button>
        <button class="modal-confirm-btn" bindtap="handleLogin">登录</button>
      </view>
    </view>
  </view>
  
  <!-- 待审批提醒弹窗 -->
  <view class="pending-alert-modal" wx:if="{{showPendingAlert}}">
    <view class="alert-mask" bindtap="closePendingAlert"></view>
    <view class="alert-content">
      <view class="alert-header">
        <text class="alert-icon">🔔</text>
        <text class="alert-title">待审批提醒</text>
      </view>
      
      <view class="alert-body">
        <text class="alert-message">
          检测到 {{pendingCount}} 条待审批的请假申请
        </text>
        <view class="applicants-list" wx:if="{{pendingApplicants.length > 0}}">
          <text class="applicants-label">申请人：</text>
          <view class="applicant-tags">
            <text 
              class="applicant-tag" 
              wx:for="{{pendingApplicants}}" 
              wx:key="index"
            >
              {{item}}
            </text>
          </view>
        </view>
      </view>
      
      <view class="alert-footer">
        <button class="alert-cancel-btn" bindtap="closePendingAlert">稍后处理</button>
        <button class="alert-confirm-btn" bindtap="goToApproval">去审批</button>
      </view>
    </view>
  </view>
  
  <cloud-tip-modal showTipProps="{{showTip}}" title="{{title}}" content="{{content}}"></cloud-tip-modal>
</view>