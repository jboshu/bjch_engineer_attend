/* pages/calendar/calendar.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
  background: #f5f5f5;
  box-sizing: border-box;
  width: 100%;
  max-width: 100vw;
  overflow-x: hidden;
}

.header {
  text-align: center;
  margin-bottom: 30rpx;
}

.current-month {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.next-month {
  font-size: 28rpx;
  color: #666;
  display: block;
}

/* 星期标题容器 */
.week-header {
  display: grid; /* 关键：改为Grid布局，与日历保持一致 */
  grid-template-columns: repeat(7, 1fr); /* 7列均分 */
  width: 100%;
  background: white;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
  box-sizing: border-box;
  padding: 0; /* 确保没有额外内边距 */
}

/* 星期标题每一项 */
.week-day {
  /* 取消Flex，改为Grid内部项 */
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  font-weight: 500;
  color: #666;
  background: #f8f8f8;
  box-sizing: border-box;
  /* 确保没有margin，否则会错位 */
  margin: 0;
}

/* 日历网格 */
.calendar-grid {
  display: grid;
  /* 关键：确保严格7列，每列宽度1fr，且没有Gap或者Gap被算入内边距 */
  grid-template-columns: repeat(7, 1fr);
  /* 如果有gap，必须配合box-sizing或者减少内边距，此处建议去掉gap或用padding替代 */
  /* gap: 6rpx;  <- 建议如果要对齐，先注释掉gap或改为padding */
  margin-bottom: 40rpx;
  width: 100%;
  max-width: 100vw; /* 确保宽度不溢出 */
  box-sizing: border-box;
  padding: 0 4rpx; /* 左右4rpx padding如果影响对齐，建议改为0 */
}

.calendar-day {
  background: white;
  border-radius: 10rpx;
  min-height: 110rpx;
  padding: 6rpx;
  position: relative;
  box-sizing: border-box;
  /* 关键：确保每一列严格居中，没有左右内边距差异 */
  display: flex;
  flex-direction: column;
  align-items: center; /* 增加这一行，让数字水平居中 */
  overflow: hidden;
}

.calendar-day.other-month {
  opacity: 0.4;
  background: #fafafa;
}

.calendar-day.next-month {
  opacity: 0.7;
  background: #f0f8ff;
  border: 1rpx solid #d6e4ff;
}

.calendar-day.has-leave {
  background: #fff7e6;
  border: 2rpx solid #ffd591;
  box-shadow: 0 2rpx 8rpx rgba(250, 140, 22, 0.2);
}

.day-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 3rpx;
  height: 28rpx;
}

.day-number {
  font-size: 28rpx;
  color: #333;
  text-align: center;
  flex: 1;
}

.month-label {
  font-size: 18rpx;
  color: #999;
  background: rgba(0,0,0,0.05);
  padding: 2rpx 6rpx;
  border-radius: 6rpx;
  white-space: nowrap;
}

.leave-info {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  flex: 1;
  min-height: 65rpx;
  max-height: 85rpx;
  overflow-y: auto;
  /* 滚动条样式 */
  scrollbar-width: thin;
  scrollbar-color: #d9d9d9 transparent;
}

/* Webkit浏览器滚动条样式 */
.leave-info::-webkit-scrollbar {
  width: 6rpx;
}

.leave-info::-webkit-scrollbar-track {
  background: transparent;
}

.leave-info::-webkit-scrollbar-thumb {
  background: #d9d9d9;
  border-radius: 3rpx;
}

.leave-info::-webkit-scrollbar-thumb:hover {
  background: #bfbfbf;
}

.leave-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 18rpx;
  padding: 2rpx 4rpx;
  background: #fff7e6;
  border-radius: 4rpx;
  min-height: 24rpx;
  line-height: 1.2;
  /* 确保有足够的宽度 */
  width: 100%;
}

.leave-name {
  color: #fa8c16;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 0;
  font-size: 17rpx;
}

.leave-period {
  color: #fa8c16;
  font-weight: bold;
  background: white;
  padding: 0 3rpx;
  border-radius: 3rpx;
  margin-left: 3rpx;
  font-size: 15rpx;
  min-width: 26rpx;
  text-align: center;
}

/* 请假人数显示 */
.leave-count {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  background: #ff4d4f;
  color: white;
  border-radius: 20rpx;
  padding: 2rpx 8rpx;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  min-width: 36rpx;
  justify-content: center;
}

.count-number {
  font-weight: bold;
  margin-right: 2rpx;
}

.count-label {
  font-size: 16rpx;
  opacity: 0.9;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 40rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 图例说明 */
.legend {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 30rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
}

.legend-color {
  width: 20rpx;
  height: 20rpx;
  background: #fff7e6;
  border-radius: 4rpx;
  margin-right: 10rpx;
}

.legend-symbol {
  width: 30rpx;
  height: 30rpx;
  background: white;
  border: 2rpx solid #fa8c16;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: bold;
  color: #fa8c16;
  margin-right: 10rpx;
}

.legend-text {
  color: #666;
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  /* 强制阻止背景滚动 */
  touch-action: none;
  overscroll-behavior: none;
}

.modal-overlay.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  background: white;
  border-radius: 20rpx;
  /* 改为弹性宽度，避免固定值导致的挤压 */
  width: calc(100% - 40rpx); /* 左右各留20rpx边距 */
  max-width: 750rpx; /* 适当减小最大宽度，适配更多设备 */
  max-height: 80vh; /* 略微增加高度，给内容更多空间 */
  display: flex;
  flex-direction: column;
  transform: scale(0.9);
  transition: transform 0.3s ease;
  overflow: hidden;
  touch-action: none;
  box-sizing: border-box;
}

.modal-overlay.show .modal-content {
  transform: scale(1);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  flex-shrink: 0; /* 防止头部被压缩 */
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  flex: 1;
}

.close-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: bold;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  cursor: pointer;
}

.modal-body {
  flex: 1;
  max-height: calc(70vh - 180rpx);
  padding: 20rpx 40rpx 10rpx;
  box-sizing: border-box;
  /* 关键：开启垂直滚动，这是唯一的滚动容器 */
  overflow-y: auto; 
  /* 可选：美化滚动条 */
  scrollbar-width: thin;
}

.leave-summary {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background: #f0f8ff;
  border-radius: 12rpx;
  border: 2rpx solid #d6e4ff;
  /* 添加左右内边距确保不超出 */
  box-sizing: border-box;
}

.summary-text {
  font-size: 28rpx;
  color: #666;
  margin-right: 10rpx;
}

.summary-count {
  font-size: 36rpx;
  font-weight: bold;
  color: #667eea;
  margin: 0 10rpx;
}

.leave-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0;
  /* 关键：取消滚动，继承 .modal-body 的滚动 */
  overflow: visible; /* 或者 unset */
}

.leave-item-detail {
  background: #fff7e6;
  border-radius: 16rpx;
  padding: 25rpx 16rpx;
  border: 2rpx solid #ffd591;
  box-shadow: 0 4rpx 12rpx rgba(255, 213, 145, 0.3);
  width: 100%;
  max-width: 100%;
  box-sizing: border-box; /* 确保内边距不增加总宽度 */
}

.leave-person {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
  /* 允许换行，防止超长名字和时段挤在一起 */
  flex-wrap: wrap;
  gap: 10rpx;
}

.person-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1 1 auto; /* 允许收缩和增长 */
  min-width: 120rpx; /* 设置最小宽度，避免名字过短 */
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.person-period {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: bold;
  min-width: 50rpx;
  text-align: center;
  flex-shrink: 0; /* 防止时段标签被压缩 */
}

.person-period.full {
  background: #ff4d4f;
  color: white;
}

.person-period.morning {
  background: #1890ff;
  color: white;
}

.person-period.afternoon {
  background: #52c41a;
  color: white;
}

.leave-reason {
  display: flex;
  align-items: flex-start;
}

.reason-label {
  font-size: 26rpx;
  color: #666;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.reason-text {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  line-height: 1.4;
}

.no-leave {
  text-align: center;
  padding: 60rpx 0;
}

.no-leave-text {
  font-size: 32rpx;
  color: #999;
}

.modal-footer {
  padding: 40rpx 30rpx 24rpx;
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  text-align: center;
  border-top: 2rpx solid #f0f0f0;
  flex-shrink: 0;
  /* 增加最小高度，确保按钮不会被压缩 */
  min-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-button {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 60rpx;
  font-size: 30rpx;
  font-weight: bold;
  /* 确保按钮不会超出容器 */
  width: auto;
  max-width: 100%;
  box-sizing: border-box;
}