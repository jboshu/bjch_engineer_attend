/* pages/approval/approval.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 标签页导航 */
.tabs {
  display: flex;
  background: white;
  border-bottom: 2rpx solid #eee;
}

.tab-item {
  flex: 1;
  padding: 30rpx 0;
  text-align: center;
  position: relative;
}

.tab-item.active {
  color: #667eea;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  width: 60%;
  height: 6rpx;
  background: #667eea;
  border-radius: 3rpx;
}

.tab-title {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 10rpx;
}

.tab-count {
  display: inline-block;
  background: #ff4d4f;
  color: white;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
  min-width: 30rpx;
  text-align: center;
}

.tab-item.active .tab-count {
  background: #667eea;
}

/* 内容区域 */
.content {
  padding: 20rpx;
}

.list-container {
  min-height: 60vh;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 申请卡片 */
.application-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.application-card {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.05);
}

.application-card.approved {
  border-left: 8rpx solid #52c41a;
}

.application-card.rejected {
  border-left: 8rpx solid #ff4d4f;
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.applicant-info {
  display: flex;
  flex-direction: column;
}

.applicant-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.application-date {
  font-size: 26rpx;
  color: #999;
}

.status-tag {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.status-tag.pending {
  background: #fff7e6;
  color: #fa8c16;
}

.status-tag.approved {
  background: #f6ffed;
  color: #52c41a;
}

.status-tag.rejected {
  background: #fff2f0;
  color: #ff4d4f;
}

/* 卡片主体 */
.card-body {
  padding: 30rpx;
}

.info-row {
  display: flex;
  margin-bottom: 20rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  width: 160rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.info-value.reason {
  line-height: 1.5;
}

/* 卡片底部 */
.card-footer {
  display: flex;
  padding: 0 30rpx 30rpx;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 70rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn.reject {
  background: #fff2f0;
  color: #ff4d4f;
  border: 2rpx solid #ffccc7;
}

.action-btn.approve {
  background: #667eea;
  color: white;
  border: none;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 50rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}